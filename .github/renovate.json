{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergePatch",
    "schedule:weekly"
  ],
  "mode": "full",
  "packageRules": [
    {
      "matchFileNames": [
        "global.json"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "enabled": false
    },
    {
      "matchFileNames": [
        "**/NdapiSourceGenerator.csproj"
      ],
      "matchPackageNames": [
        "Microsoft.CodeAnalysis.Analyzers",
        "Microsoft.CodeAnalysis.CSharp"
      ],
      "enabled": false
    }
  ]
}
